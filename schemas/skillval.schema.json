{
  "type": "object",
  "required": ["cases", "class", "skill"],
  "properties": {
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "mode", "prompt"],
        "properties": {
          "arms": {
            "type": "array",
            "items": {
              "enum": ["baseline", "solo"]
            },
            "uniqueItems": true
          },
          "assert": {
            "type": "object",
            "properties": {
              "command_exit": {
                "type": "object",
                "required": ["command"],
                "properties": {
                  "command": {
                    "type": "string",
                    "description": "Shell command run in the workspace; the grader passes when it exits as expected. Trusted case input: this is arbitrary shell executed on the grading machine (see the README's Trust model section).",
                    "minLength": 1,
                    "pattern": "\\S"
                  },
                  "expect": {
                    "type": "integer",
                    "description": "Exit code the command must produce to pass. Defaults to 0.",
                    "maximum": 255,
                    "minimum": 0
                  }
                },
                "additionalProperties": false
              },
              "graders": {
                "type": "array",
                "items": {
                  "enum": ["tsc"]
                },
                "uniqueItems": true
              },
              "json_schema": {
                "type": "object",
                "required": ["file", "schema"],
                "properties": {
                  "file": {
                    "type": "string",
                    "description": "Produced file, relative to the workspace, parsed as JSON and validated.",
                    "minLength": 1,
                    "pattern": "\\S"
                  },
                  "schema": {
                    "anyOf": [
                      {
                        "type": "object",
                        "patternProperties": {
                          "^.*$": {}
                        }
                      },
                      {
                        "type": "boolean"
                      }
                    ],
                    "description": "JSON Schema (draft 2020-12) the produced file must satisfy; an object or a boolean schema. Omit $schema, or set it to 2020-12; other declared dialects are rejected."
                  }
                },
                "additionalProperties": false
              },
              "must_match": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "must_not_match": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            },
            "additionalProperties": false
          },
          "fixture": {
            "type": "object",
            "properties": {
              "path": {
                "type": "string",
                "description": "Directory relative to skillval.yml, copied into the workspace.",
                "minLength": 1,
                "pattern": "\\S"
              },
              "setup": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1,
                  "pattern": "\\S"
                },
                "description": "Shell commands run sequentially inside the workspace after the copy. Trusted case input: arbitrary shell executed on the grading machine (see the README's Trust model section)."
              }
            },
            "additionalProperties": false,
            "minProperties": 1
          },
          "id": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S"
          },
          "mode": {
            "enum": ["generation", "trigger"]
          },
          "prompt": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S"
          },
          "rule": {
            "type": "string"
          },
          "should_trigger": {
            "type": "boolean"
          },
          "trials": {
            "type": "integer",
            "maximum": 5,
            "minimum": 1
          },
          "type": {
            "enum": ["capability", "preference"]
          }
        },
        "additionalProperties": false
      }
    },
    "class": {
      "enum": ["capability", "preference"]
    },
    "fixture": {
      "type": "object",
      "properties": {
        "path": {
          "type": "string",
          "description": "Directory relative to skillval.yml, copied into the workspace.",
          "minLength": 1,
          "pattern": "\\S"
        },
        "setup": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S"
          },
          "description": "Shell commands run sequentially inside the workspace after the copy. Trusted case input: arbitrary shell executed on the grading machine (see the README's Trust model section)."
        }
      },
      "additionalProperties": false,
      "minProperties": 1
    },
    "skill": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    }
  },
  "$id": "https://raw.githubusercontent.com/dungle-scrubs/skillval/main/schemas/skillval.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "title": "skillval case file"
}
